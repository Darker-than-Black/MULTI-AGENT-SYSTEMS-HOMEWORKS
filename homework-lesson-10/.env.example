OPENAI_API_KEY=
GITHUB_TOKEN=
MODEL_NAME=gpt-5.4-nano
EMBEDDING_MODEL=text-embedding-3-small
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge-base
COHERE_API_KEY=
RERANK_MODEL=rerank-v3.5
KNOWLEDGE_DATA_DIR=data
KNOWLEDGE_CORPUS_PATH=.rag/knowledge-corpus.json
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
KNOWLEDGE_TOP_K=6
KNOWLEDGE_RERANK_TOP_N=4
MAX_SEARCH_RESULTS=20
MAX_URL_CONTENT_LENGTH=10000
MAX_SESSION_MESSAGES=80
MAX_MESSAGE_CONTENT_CHARS=4000
OUTPUT_DIR=output
MAX_ITERATIONS=10
TEMPERATURE=0.2
SUPERVISOR_MAX_RESEARCH_REVISIONS=2
SUPERVISOR_MIN_RECURSION_LIMIT=30
SUPERVISOR_RECURSION_MULTIPLIER=7
PLANNER_RECURSION_LIMIT=8
CRITIC_RECURSION_LIMIT=8
RESEARCH_WORKFLOW_MIN_RECURSION_LIMIT=14
RESEARCH_WORKFLOW_QUERY_RECURSION_FACTOR=4
RESEARCH_WORKFLOW_QUERY_RECURSION_OFFSET=2
RESEARCH_TURN_MIN_RECURSION_LIMIT=10
RESEARCH_TURN_RECURSION_MULTIPLIER=3

# --- Python test layer (homework-lesson-10) ---
# Model used by DeepEval's LLM-as-judge
DEEPEVAL_JUDGE_MODEL=gpt-4o-mini
# Set to 1 to skip live agent invocation and use cached outputs
DEEPEVAL_OFFLINE=0
# Bounds used only by tests when they invoke `npm run batch`
DEEPEVAL_AGENT_MAX_ITERATIONS=3
DEEPEVAL_AGENT_MAX_REVISIONS=0
DEEPEVAL_AGENT_TIMEOUT_SECONDS=180
